{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["vite/client", "vue/ref-macros", "node"]
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "src/main.js", "src/router/index.js"],
  "exclude": ["node_modules", "dist", "src/**/*.js"]
}